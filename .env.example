# ============================================
# Environment Configuration
# Copy this file to .env and adjust values
# ============================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mimic_prediction
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/mimic_prediction

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your-secret-key-change-in-production
SESSION_MAX_AGE=3600

# ML Service
ML_SERVICE_HOST=0.0.0.0
ML_SERVICE_PORT=8001
ML_SERVICE_URL=http://ml_service:8001

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=postgresql://postgres:postgres@postgres:5432/mlflow
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# MIMIC Data Path (inside container)
MIMIC_DIR=/data/mimic-iv-clinical-database-demo-2.2

# Frontend
VITE_API_URL=http://localhost:8000/api
